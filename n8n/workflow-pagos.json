{
  "name": "AgutiDesigns — Tracking de Pagos (Holded)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "holded-payment-webhook",
        "options": { "responseCode": 200 }
      },
      "id": "b1c2d3e4-0001-0001-0001-000000000001",
      "name": "💳 Holded Webhook (pago)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "holded-payment-webhook"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.event }}",
              "rightValue": "estimateAccepted",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "b1c2d3e4-0002-0002-0002-000000000002",
      "name": "🤔 ¿Es un presupuesto aceptado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.holded.com/api/invoices/v1/estimate/{{ $('💳 Holded Webhook (pago)').item.json.docId }}/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "b1c2d3e4-0003-0003-0003-000000000003",
      "name": "📄 Holded — Obtener detalle presupuesto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 200],
      "credentials": { "httpHeaderAuth": { "id": "holded-cred", "name": "Holded API" } }
    },
    {
      "parameters": {
        "operation": "search",
        "base": { "__rl": true, "value": "={{ $env.AIRTABLE_BASE_ID }}", "mode": "id" },
        "table": { "__rl": true, "value": "Leads", "mode": "name" },
        "filterByFormula": "={{ \"AND({Holded Estimate ID}='\" + $('💳 Holded Webhook (pago)').item.json.docId + \"')\" }}"
      },
      "id": "b1c2d3e4-0004-0004-0004-000000000004",
      "name": "🔍 Airtable — Buscar lead por presupuesto",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [900, 200],
      "credentials": { "airtableTokenApi": { "id": "airtable-cred", "name": "Airtable" } }
    },
    {
      "parameters": {
        "operation": "update",
        "base": { "__rl": true, "value": "={{ $env.AIRTABLE_BASE_ID }}", "mode": "id" },
        "table": { "__rl": true, "value": "Leads", "mode": "name" },
        "id": "={{ $json.id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Status":   "ganado",
            "Paid At":  "={{ new Date().toISOString() }}",
            "Notes":    "Presupuesto aceptado en Holded"
          }
        }
      },
      "id": "b1c2d3e4-0005-0005-0005-000000000005",
